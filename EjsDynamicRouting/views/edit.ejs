<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/styles.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-10 text-white">
        <a class="text-blue-500 inline-block mb-10" href="/">Go back to Hompage</a>
        <form action="/edit" method="post">
            <input class="w-1/4 block px-5 py-2 bg-zinc-800 outline-none rounded-md" placeholder="Previous name" type="text" name="previous" value=<%=filename%>>
            <input class="w-1/4 block px-5 py-2 bg-zinc-800 outline-none rounded-md mt-2" placeholder="New name" type="text" name="new">
            <input class="bg-yellow-500 px-5 py-2 active:scale-95 rounded mt-2" type="submit" value="Update Name">
        </form>
    </div>
    
</body>
</html>