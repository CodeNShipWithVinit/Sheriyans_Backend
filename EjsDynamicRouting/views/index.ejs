<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/styles.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 ">
        <div class="form p-10 text-white">
            <form action="/create" method="post">
                <input class="w-full block px-5 py-2 bg-zinc-800 outline-none rounded-md" placeholder="Title goes here..." type="text" name="title">
                <textarea class="w-full block mt-2 px-5 py-2 resize-none outline-none rounded-md bg-zinc-800" placeholder="Write your task details here..." name="details" id=""></textarea>
                <input class="bg-blue-800 px-5 py-2 active:scale-95 rounded mt-2" type="submit" value="Create Task">
            </form>
        </div>
        <div class="tasks flex gap-3 flex-wrap p-10">

           <% if(files.length>0){ %>
               <% files.forEach(function(val){ %>
                    <div class="task max-w-72 px-3 py-4 rounded-md bg-zinc-800">
                        <h1 class="text-white text-2xl tracking-tighter"><%=val%></h1>
                        <div class="w-full flex justify-between items-center mt-3">
                            <a class="text-blue-500 inline-block " href="/files/<%= val %>">Read more...</a>
                            <a class="text-zinc-600" href="/edit/<%=val%>">edit filename</a>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <h3 class="text-zinc-600">No tasks yet.</h3>
            <% } %>
            
        </div>
    </div>
    
    <script src="/javascripts/script.js"></script>
</body>
</html>